# Token de tu bot (obtenlo en https://discord.com/developers/applications)
DISCORD_TOKEN=

# ID de tu aplicación (Application ID en el portal de desarrolladores)
CLIENT_ID=

# ID del servidor donde desplegar los comandos (para desarrollo)
GUILD_ID=

# URI de conexión a MongoDB
MONGO_URI=mongodb://localhost:27017/discordbot

# ID del canal donde se enviarán las sugerencias
SUGGESTIONS_CHANNEL_ID=

# ID del canal donde se enviarán los mensajes de cumpleaños
BIRTHDAY_CHANNEL_ID=

# (Opcional) ID del rol que se asignará temporalmente en cumpleaños
BIRTHDAY_ROLE_ID=
